<odoo>
    <record id="product_template_form_custom" model="ir.ui.view">
        <field name="name">product.template.custom</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">

            <xpath expr="//div[@class='o_row w-100']" position="after">
                <field name="ctn_size"/>
                <field name="grams"/>
                <field name="trade_price"/>
                <field name="msrp"/>
            </xpath>

        </field>
    </record>
</odoo>